# ==================== 校享云 环境变量模板 ====================
# 复制此文件为 .env 并填入真实密码
# cp .env.example .env
#
# ⚠️ .env 文件已在 .gitignore 中排除，不会被提交到 Git

# ==================== MySQL ====================
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==================== RabbitMQ ====================
MQ_HOST=localhost
MQ_PORT=5672
MQ_USER=guest
MQ_PASSWORD=your_rabbitmq_password_here

# ==================== Jasypt 配置加密主密钥 ====================
JASYPT_PASSWORD=your_jasypt_key_here

# ==================== MinIO 对象存储 ====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_password_here

# ==================== Nacos ====================
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=campus-cloud
